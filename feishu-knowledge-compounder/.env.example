# Required for Feishu app authentication
FEISHU_APP_ID="cli_xxx"
FEISHU_APP_SECRET="xxx"

# Optional alternative: use a user access token instead of tenant access token
# FEISHU_USER_ACCESS_TOKEN="u-xxx"
# FEISHU_ACCESS_TOKEN="xxx"
# FEISHU_ACCESS_TOKEN_KIND="user"

# Optional: where to create a new Base during bootstrap
FEISHU_BASE_FOLDER_TOKEN="fld_xxx"

# Optional: where to create tutorial documents
# FEISHU_DOC_PARENT_URL="https://trip.larkenterprise.com/wiki/wiki_xxx"
# FEISHU_DOC_PARENT_TOKEN="wik_xxx"

# Recommended after bootstrap
FEISHU_COMPOUNDER_CONFIG="/absolute/path/to/feishu-config.json"

# Optional: direct storage config if you do not use a config file
FEISHU_BASE_APP_TOKEN="app_xxx"
FEISHU_CONVERSATIONS_TABLE_ID="tbl_xxx"
FEISHU_GAPS_TABLE_ID="tbl_xxx"
FEISHU_READING_TABLE_ID="tbl_xxx"

# Reminder target via app message API
FEISHU_NOTIFY_OPEN_ID="ou_xxx"
# FEISHU_NOTIFY_CHAT_ID="oc_xxx"
# FEISHU_NOTIFY_RECEIVE_ID="ou_xxx"
# FEISHU_NOTIFY_RECEIVE_ID_TYPE="open_id"

# Reminder target via custom bot webhook
# FEISHU_NOTIFY_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/xxx"
# FEISHU_NOTIFY_WEBHOOK_SECRET="xxx"
